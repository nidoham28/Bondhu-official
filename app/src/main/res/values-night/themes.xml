<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    Main application theme. This is applied in the Activity's onCreate.
    The transparent background allows the Compose UI to draw the app's background.
    -->
    <style name="Theme.Bondhu" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background_dark</item>
    </style>

    <!-- Splash Screen Theme for Dark Mode -->
    <style name="Theme.Bondhu.Splash" parent="@style/Theme.Bondhu">
        <item name="android:windowBackground">@color/splash_background_dark</item>
    </style>
</resources>