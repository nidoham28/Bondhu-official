<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        On API 31+, the system renders the splash screen using these attributes.
        windowSplashScreenBackground must match the app background to prevent
        a visible color flash during the handoff from the splash to the main theme.
        windowSplashScreenAnimatedIcon is the adaptive icon shown at launch.
    -->
    <style name="Theme.Bondhu.Splash" parent="Theme.Bondhu">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher</item>
    </style>
</resources>